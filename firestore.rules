rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow access to the user document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Allow access to any subcollections under the user (e.g. users/{uid}/colors/{doc})
      match /{subCollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}

